{
  "version": 1,
  "rules": [
    {
  "id": "earthing_reading",
  "priority": 10,
  "match_any": ["earthing reading", "earthing", "earth resistance", "earth tester"],
  "task_kind": "earthing",
  "mode_hint": "numeric_strict",
  "expected_output_type": "number",
  "expected_object": "digital earth resistance tester LCD display",
  "allow_local_ocr_fallback": false,
  "require_object_presence_for_value": true,
  "alert_when_required_object_missing": true,
  "requires_ai": true,
  "unit": "ohm",
  "value_format": {
    "type": "decimal_number",
    "allow_negative": false,
    "allow_units_in_value": false,
    "min": 0,
    "max": 100,
    "decimal_places_max": 2
  },
  "reading_rules": {
    "source_of_truth": "meter_display_only",
    "read_only_visible_lcd_digits": true,
    "reject_if_display_not_clear": true,
    "reject_if_digits_partially_hidden": true,
    "reject_if_display_has_glare_or_blur": true,
    "reject_if_multiple_possible_values": true,
    "do_not_infer_or_guess_missing_digits": true,
    "ignore_body_text_labels": true,
    "ignore_timestamp_overlay": true,
    "ignore_brand_name": true,
    "ignore_background_objects": true,
    "extract_single_most_prominent_display_value": true
  },
  "inspection_points": [
    "Locate a digital earth resistance tester in the image.",
    "Confirm the device display is clearly visible.",
    "Read only the numeric value shown inside the LCD display window.",
    "Do not read text printed on the meter body such as E1, P1, P2, E2, CHARGE, TEST, 1000Ω, OFF, or 10Ω.",
    "Do not use timestamp text or any overlaid text in the image.",
    "Return the value only if all digits are clearly visible and unambiguous.",
    "If the display is unclear, obstructed, tilted too much, blurred, washed out, or reflective, return no value instead of guessing.",
    "For this task, prefer a decimal reading exactly as shown on the screen."
  ],
  "ai_extraction_contract": {
    "must_return": {
      "value": "number|null",
      "unit": "ohm",
      "object_present": "boolean",
      "display_visible": "boolean",
      "confidence": "number",
      "raw_display_text": "string",
      "reason_if_null": "string"
    },
    "accept_if": {
      "object_present": true,
      "display_visible": true,
      "confidence_gte": 0.95
    },
    "otherwise_return_null": true
  },
  "validation_rules": [
    {
      "type": "require_decimal_or_integer_pattern",
      "pattern": "^[0-9]+(\\.[0-9]{1,2})?$"
    }
  ],
  "alert_threshold": {
    "operator": "gt",
    "value": 1.5,
    "message": "Task alert: Earthing value {value} ohm exceeded 1.5 ohm for task '{title}'."
  }
},
    {
      "id": "surrounding_area_eqpt_room",
      "priority": 20,
      "match_any": ["surrounding area", "eqpt room", "equipment room"],
      "task_kind": "area_maintenance",
      "mode_hint": "label",
      "expected_output_type": "label",
      "expected_object": "equipment room surrounding area",
      "allowed_labels": ["Area maintained", "Area Not maintained"],
      "requires_ai": true,
      "inspection_points": [
        "Check for over hanging cables",
        "Check overall cleanliness",
        "Check proper layout of equipment"
      ],
      "return_label_when": {
        "good": "Area maintained",
        "bad": "Area Not maintained"
      },
      "alert_on_values": ["Area Not maintained"],
      "alert_message": "Task alert: Area not maintained for task '{title}'. Findings: {evidence}"
    },
    {
      "id": "fire_fighting_serviceable",
      "priority": 30,
      "match_all": ["fire fighting equipment"],
      "match_any": ["serviceable", "unserviceable"],
      "task_kind": "serviceability_check",
      "mode_hint": "label",
      "expected_output_type": "label",
      "expected_object": "fire extinguisher spray condition",
      "allowed_labels": ["Serviceable", "Unserviceable"],
      "requires_ai": true,
      "inspection_points": [
        "Check whether spray is coming out of the fire extinguisher",
        "Mark it serviceable only if the image shows it is working"
      ],
      "alert_on_values": ["Unserviceable"],
      "alert_message": "Task alert: Fire fighting equipment is unserviceable for task '{title}'. Findings: {evidence}"
    },
    {
      "id": "voltage_reading",
      "priority": 35,
      "match_any": ["voltage reading", "voltage", "volt meter", "voltmeter"],
      "task_kind": "voltage",
      "mode_hint": "numeric_strict",
      "expected_output_type": "number",
      "expected_object": "digital voltage meter display",
      "allow_local_ocr_fallback": false,
      "require_object_presence_for_value": true,
      "alert_when_required_object_missing": true,
      "requires_ai": true,
      "unit": "V",
      "value_format": {
        "type": "decimal_number",
        "allow_negative": false,
        "allow_units_in_value": false,
        "min": 0,
        "max": 500,
        "decimal_places_max": 2
      },
      "reading_rules": {
        "source_of_truth": "meter_display_only",
        "read_only_visible_lcd_digits": true,
        "reject_if_display_not_clear": true,
        "reject_if_digits_partially_hidden": true,
        "reject_if_display_has_glare_or_blur": true,
        "reject_if_multiple_possible_values": true,
        "do_not_infer_or_guess_missing_digits": true,
        "ignore_body_text_labels": true,
        "ignore_timestamp_overlay": true,
        "ignore_brand_name": true,
        "ignore_background_objects": true,
        "extract_single_most_prominent_display_value": true
      },
      "inspection_points": [
        "Locate the voltage meter or voltmeter in the image.",
        "Confirm the display is clearly visible and readable.",
        "Read only the numeric value shown on the meter display.",
        "Do not use printed labels, meter body text, timestamps, or background numbers.",
        "If the display is unclear, obstructed, reflective, blurred, or ambiguous, return no value instead of guessing."
      ],
      "ai_extraction_contract": {
        "must_return": {
          "value": "number|null",
          "unit": "V",
          "object_present": "boolean",
          "display_visible": "boolean",
          "confidence": "number",
          "raw_display_text": "string",
          "reason_if_null": "string"
        },
        "accept_if": {
          "object_present": true,
          "display_visible": true,
          "confidence_gte": 0.95
        },
        "otherwise_return_null": true
      },
      "validation_rules": [
        {
          "type": "require_decimal_or_integer_pattern",
          "pattern": "^[0-9]+(\\.[0-9]{1,2})?$"
        }
      ],
      "alert_threshold": {
        "operator": "lt",
        "value": 11.5,
        "message": "Task alert: Voltage value {value} V is below 11.5 V for task '{title}'."
      }
    },
    {
      "id": "odometer_reading",
      "priority": 40,
      "match_any": ["odometer reading", "odometer"],
      "task_kind": "odometer",
      "mode_hint": "numeric",
      "expected_output_type": "number",
      "expected_object": "odometer display",
      "requires_ai": true,
      "inspection_points": [
        "Read hours or odometer values from both uploaded images",
        "Calculate the difference between start and end values",
        "Calculate fuel consumed using average kmpl"
      ]
    },
    {
      "id": "fire_point_check",
      "priority": 50,
      "match_any": ["fire point check", "fire point", "firepoint"],
      "task_kind": "fire_point",
      "mode_hint": "present_absent",
      "expected_output_type": "present_absent",
      "expected_object": "fire extinguisher or fire buckets",
      "allowed_labels": ["Present", "Absent"],
      "requires_ai": true,
      "inspection_points": [
        "Check whether fire extinguishers or fire buckets are visible"
      ],
      "alert_on_values": ["Absent"],
      "alert_message": "Task alert: Fire fighting equipment absent for task '{title}'."
    },
    {
      "id": "telephone_line_repairing_status",
      "priority": 60,
      "match_any": ["telephone line repairing status", "telephone of line repairing status"],
      "task_kind": "unsupported_notice",
      "expected_output_type": "text",
      "requires_ai": false,
      "unsupported_message": "This is not supported yet kindly see the image"
    },
    {
      "id": "karo_heater",
      "priority": 70,
      "match_any": [
        "karo heater",
        "karoheater",
        "kero heater",
        "keroheater",
        "keeoheater",
        "keeoheaters",
        "kero heaters",
        "bhukhari",
        "bukhari",
        "bukhaari",
        "bhukhari photos bhejiye",
        "update your karo heater off time"
      ],
      "task_kind": "heater_flame_check",
      "mode_hint": "label",
      "expected_output_type": "label",
      "expected_object": "heater flame",
      "allowed_labels": ["ON", "OFF"],
      "requires_ai": true,
      "inspection_points": [
        "Check whether a flame or fire is visibly coming from the kero heater or bhukhari",
        "Return ON only if a visible flame, burner fire, or combustion glow is present in the heater",
        "Return OFF if no visible flame or fire is coming from the heater"
      ],
      "alert_on_values": ["ON"],
      "alert_message": "Task alert: Kero heater is ON for task '{title}'."
    },
    {
      "id": "timestamp_value",
      "priority": 80,
      "match_any": ["timestamp", "time stamp", "time-stamp"],
      "task_kind": "timestamp_value",
      "expected_output_type": "text",
      "requires_ai": false,
      "use_image_timestamp_as_value": true,
      "missing_value_message": "No timestamp metadata found"
    }
  ]
}
